        "# --- 1. GENERAR PROBABILIDADES PARA TODO EL DATASET ---\n",
        "# Usamos el escalador que definimos antes (scaler) sobre las variables (X)\n",
        "X_all_scaled = scaler.transform(X)\n",
        "master_df['Churn_Probability'] = model.predict_proba(X_all_scaled)[:, 1]\n",
        "\n",
        "# --- 2. DEFINIR EL NIVEL DE RIESGO (RISK LEVEL) ---\n",
        "master_df['Risk_Level'] = pd.cut(master_df['Churn_Probability'],\n",
        "                                 bins=[0, 0.4, 0.7, 1.0],\n",
        "                                 labels=['Bajo', 'Medio', 'Alto'])\n",
        "\n",
        "# --- 3. PEGAR AQUÍ EL CÓDIGO DE ACCIÓN SUGERIDA ---\n",
        "def definir_accion(row):\n",
        "    umbral_valor = master_df['Monetary'].median()\n",
        "    if row['Churn_Probability'] > 0.8 and row['Monetary'] > umbral_valor:\n",
        "        return \"Rescate VIP: Contacto Directo / Oferta Exclusiva\"\n",
        "    elif row['Churn_Probability'] > 0.6:\n",
        "        return \"Alerta de Fuga: Campaña de Re-engagement\"\n",
        "    elif row['Churn_Probability'] < 0.3 and row['Monetary'] > umbral_valor:\n",
        "        return \"Fidelizar: Programa de Recompensas VIP\"\n",
        "    else:\n",
        "        return \"Monitoreo: Seguimiento Estándar\"\n",
        "\n",
        "master_df['Accion_Sugerida'] = master_df.apply(definir_accion, axis=1)\n",
        "\n",
        "# Ver distribución final\n",
        "print(master_df['Accion_Sugerida'].value_counts())"
