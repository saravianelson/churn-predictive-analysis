    {
      "cell_type": "code",
      "source": [
        "# Selección de variables para el modelo\n",
        "features = ['Frequency_Log', 'Monetary_Log', 'Avg_Ticket']\n",
        "X = master_df[features]\n",
        "y = master_df['CHURN']\n",
        "\n",
        "# Escalado de datos (Crucial para que el modelo no se sesgue por el tamaño de los números)\n",
        "scaler = StandardScaler()\n",
        "X_scaled = scaler.fit_transform(X)\n",
        "\n",
        "# División del dataset para validación\n",
        "X_train, X_test, y_train, y_test = train_test_split(X_scaled, y, test_size=0.2, random_state=42)\n",
        "\n",
        "# Inicialización y entrenamiento del Bosque Aleatorio (Random Forest)\n",
        "model = RandomForestClassifier(n_estimators=100, max_depth=12, random_state=42)\n",
        "model.fit(X_train, y_train)\n",
        "\n",
        "# Generación de Probabilidades de Fuga (Score de Riesgo)\n",
        "master_df['Churn_Probability'] = model.predict_proba(scaler.transform(X))[:, 1]\n",
        "\n",
        "# Clasificación de niveles de riesgo para el equipo de Negocio/Dashboard\n",
        "master_df['Risk_Level'] = pd.cut(master_df['Churn_Probability'],\n",
        "                                 bins=[0, 0.4, 0.7, 1.0],\n",
        "                                 labels=['Bajo', 'Medio', 'Alto'])"
      ],
