        "id": "O1Oh7Ka96DJt"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Carga del dataset (Asegúrate de tener el archivo en el entorno de Colab)\n",
        "df = pd.read_csv(file_path)\n",
        "\n",
        "# 1. Eliminación de registros sin identidad (Vital para seguimiento de clientes)\n",
        "df_clean = df.dropna(subset=['Customer ID'])\n",
        "\n",
        "# 2. Limpieza de transacciones: eliminamos devoluciones (Quantity < 0) y ajustes\n",
        "df_clean = df_clean[(df_clean['Quantity'] > 0) & (df_clean['Price'] > 0)]\n",
        "\n",
        "# 3. Formateo de fechas y creación de métrica de venta\n",
        "df_clean['InvoiceDate'] = pd.to_datetime(df_clean['InvoiceDate'])\n",
        "df_clean['Total_Sales'] = df_clean['Quantity'] * df_clean['Price']\n",
        "\n",
        "print(f\"Dataset procesado: {df_clean.shape[0]} registros válidos.\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "7Er6p75c6mi-",
        "outputId": "55f38310-2e00-4c3e-aecc-f6f36d693acb"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Dataset procesado: 805549 registros válidos.\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "3"
      ],
      "metadata": {
        "id": "4RhjTcfF6rxK"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Establecemos la fecha de referencia para el cálculo de Recencia\n",
        "snapshot_date = df_clean['InvoiceDate'].max() + dt.timedelta(days=1)\n",
        "\n",
        "# Agrupamos por cliente para obtener el comportamiento histórico\n",
        "master_df = df_clean.groupby('Customer ID').agg({\n",
        "    'InvoiceDate': lambda x: (snapshot_date - x.max()).days,\n",
        "    'Invoice': 'nunique',\n",
        "    'Total_Sales': 'sum'\n",
        "}).reset_index()\n",
        "\n",
        "# Renombramos columnas para claridad técnica\n",
        "master_df.columns = ['Customer_ID', 'Recency', 'Frequency', 'Monetary']\n",
        "\n",
        "# Definición del Target: Churn (90 días de inactividad)\n",
        "master_df['CHURN'] = (master_df['Recency'] > 90).astype(int)\n",
        "\n",
        "# Ingeniería de atributos adicionales (Feature Engineering)\n",
        "master_df['Avg_Ticket'] = master_df['Monetary'] / master_df['Frequency']\n",
        "\n",
        "# Aplicamos Log Transformation para normalizar (Mejora de robustez)\n",
        "master_df['Monetary_Log'] = np.log1p(master_df['Monetary'])\n",
        "master_df['Frequency_Log'] = np.log1p(master_df['Frequency'])\n",
        "\n",
        "print(\"Tabla Maestra RFM generada con éxito.\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "jR4qPGc96tph",
